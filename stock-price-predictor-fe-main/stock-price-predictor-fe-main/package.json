{
  "name": "stock-app",
  "version": "0.0.1",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "node --eval \"const args=process.argv.slice(1).filter(a=>!/^-?-?watch(=|$)/.test(a)); const cp=require('child_process'); const res=cp.spawnSync('npx',['tsc','-p','tsconfig.json','--noEmit',...args],{stdio:'inherit'}); process.exit(res.status);\" --",
    "lint": "npm run typecheck",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "api": "node server.js",
    "start:all": "echo Run backend and frontend in two terminals: npm run api AND npm start"
  },
  "dependencies": {
    "@angular/animations": "^18.2.0",
    "@angular/common": "^18.2.0",
    "@angular/compiler": "^18.2.0",
    "@angular/core": "^18.2.0",
    "@angular/forms": "^18.2.0",
    "@angular/platform-browser": "^18.2.0",
    "@angular/platform-browser-dynamic": "^18.2.0",
    "@angular/platform-server": "^18.2.0",
    "@angular/router": "^18.2.0",
    "chart.js": "^4.4.3",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "rxjs": "~7.8.1",
    "tslib": "^2.8.1",
    "zone.js": "~0.14.10"
    ,
    "echarts": "^5.4.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.0",
    "@angular/build": "^18.2.21",
    "@angular/cli": "^18.2.0",
    "@angular/compiler-cli": "^18.2.0",
    "@types/node": "^20.14.10",
    "typescript": "~5.4.5"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.61.1"
  }
}
